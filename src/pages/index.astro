---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostItem from '@components/PostItem.astro';
import type { MarkdownInstance } from 'astro';
import { Icon } from 'astro-icon/components';

interface Frontmatter {
  title: string;
  pubDate: string;
  draft?: boolean;
}

const MAX_POSTS = 8;
const posts = await Promise.all(
  Object.values(
    import.meta.glob<MarkdownInstance<Frontmatter>>('./posts/*.{md,mdx}', {
      eager: true,
    }),
  ),
);
const pageTitle = 'Home';
const sortedPosts = posts
  .filter((post) => !post.frontmatter.draft)
  .sort((a, b) => {
    return (
      new Date(b.frontmatter.pubDate).getTime() -
      new Date(a.frontmatter.pubDate).getTime()
    );
  });
---

<BaseLayout pageTitle={pageTitle}>
  <div class="mt-10 flex w-full justify-center sm:px-4">
    <article class="container grid grid-cols-1 gap-y-16 xl:grid-cols-2">
      <section>
        <h2 class="mx-4 mb-8 border-b pb-4 text-3xl font-bold">Blog</h2>
        <ul class="grid grid-cols-1 flex-col gap-4 gap-y-2 sm:gap-y-4">
          {
            sortedPosts
              .slice(0, MAX_POSTS)
              .map((post) => <PostItem post={post} />)
          }
        </ul>
        {
          sortedPosts.length > MAX_POSTS && (
            <a
              href="/posts"
              class="mt-4 mr-4 ml-auto flex w-fit items-center gap-x-2 rounded border py-2 pr-4 pl-5 transition hover:bg-neutral-200 hover:text-neutral-900 sm:mr-0 hover:dark:bg-neutral-800 hover:dark:text-neutral-100"
            >
              もっと見る
              <Icon name="lucide:arrow-right" />
            </a>
          )
        }
      </section>
      <section class="container">
        <h2 class="mx-4 mb-8 border-b pb-4 text-3xl font-bold">Works</h2>
      </section>
    </article>
  </div>
</BaseLayout>
