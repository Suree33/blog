{
  "lspServers": {
    "astro": {
      "command": "pnpm",
      "args": ["exec", "astro-ls", "--stdio"],
      "fileExtensions": {
        ".astro": "astro"
      }
    },
    "typescript": {
      "command": "pnpm",
      "args": ["exec", "typescript-language-server", "--stdio"],
      "fileExtensions": {
        ".ts": "typescript",
        ".tsx": "typescriptreact",
        ".js": "javascript",
        ".jsx": "javascriptreact"
      }
    }
  }
}
